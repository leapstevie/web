<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
    <style>
        body {
            font-family: sans-serif;
            padding: 2rem;
        }

        h1 {
            font-size: 1.4rem;
            font-weight: 500;
            margin-bottom: 1.25rem;
        }

        .empty {
            color: #888;
        }

        .error {
            color: red;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }

        th {
            padding: 8px 12px;
            text-align: left;
            font-size: 12px;
            color: #888;
            text-transform: uppercase;
            border-bottom: 1px solid #ddd;
        }

        td {
            padding: 10px 12px;
            border-bottom: 1px solid #f0f0f0;
        }

        tr:hover td {
            background: #fafafa;
        }
    </style>
</head>

<body>
    <h1>Users</h1>

    <% if (error) { %>
        <p class="error">
            <%= error %>
        </p>
        <% } else if (!users || users.length===0) { %>
            <p class="empty">No users found.</p>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Age</th>
                            <th>Salary</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u=> { %>
                            <tr>
                                <td>
                                    <%= u.id %>
                                </td>
                                <td>
                                    <%= u.name %>
                                </td>
                                <td>
                                    <%= u.email %>
                                </td>
                                <td>
                                    <%= u.age %>
                                </td>
                                <td>
                                    <%= u.salary %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
                <% } %>

                    <img src="/asset/download.jpeg" alt="image" width="200">
</body>

</html>